{
  "github": {
    "silent": true
  },
  "regions": ["bom1"],
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
